<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect /iatutor (and subpaths, with or without language prefixes) to https://meulinux.com/pt-br/
  RewriteRule ^(pt-br/|en/)?iatutor(/.*)?$ https://meulinux.com/pt-br/ [R=301,L]

  # Redirect from old .com.br domain to new .com domain with language prefix (pt-br)
  RewriteCond %{HTTP_HOST} ^(www\.)?meulinux\.com\.br$ [NC]
  RewriteRule ^$ https://meulinux.com/pt-br/ [R=301,L]

  RewriteCond %{HTTP_HOST} ^(www\.)?meulinux\.com\.br$ [NC]
  RewriteRule ^(.*)$ https://meulinux.com/pt-br/$1 [R=301,L]

  # If target is not a real file or directory inside the build package, route via index.html (React Router)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.html [L]
</IfModule>
